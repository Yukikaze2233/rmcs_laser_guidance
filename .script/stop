#!/usr/bin/env bash
set -euo pipefail
FIFO="/tmp/laser_cmd"

if pgrep -f "tool_preview" >/dev/null 2>&1; then
    if [ -p "$FIFO" ]; then
        timeout 1 bash -c "echo 'quit' > '$FIFO'" 2>/dev/null || true
    fi
    sleep 1
    pkill -f "tool_preview" 2>/dev/null || true
    rm -f "$FIFO"
    echo "已停止"
else
    rm -f "$FIFO"
    echo "守护进程未运行"
fi
