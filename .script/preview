#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
STORE="$SCRIPT_DIR/.config-path"

CONFIG="${1:-}"
if [ -z "$CONFIG" ]; then
    if [ -f "$STORE" ]; then
        CONFIG="$(cat "$STORE")"
    else
        CONFIG="$REPO_ROOT/config/default.yaml"
    fi
fi

echo "=== 正常预览 (imshow) ==="
echo "配置: $CONFIG"
echo ""

TMP_CONFIG="$(mktemp /tmp/laser_guidance_preview_XXXX.yaml)"
cleanup() { rm -f "$TMP_CONFIG"; }
trap cleanup EXIT
python3 -c "
import yaml, sys
with open('$CONFIG') as f:
    cfg = yaml.safe_load(f)
cfg.setdefault('streaming', {})['enabled'] = False
cfg.setdefault('debug', {})['show_window'] = True
yaml.dump(cfg, sys.stdout, default_flow_style=False, allow_unicode=True)
" > "$TMP_CONFIG"
cd "$REPO_ROOT"
./build/example_v4l2_preview "$TMP_CONFIG"
