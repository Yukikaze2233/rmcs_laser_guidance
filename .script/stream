#!/usr/bin/env bash
set -euo pipefail
FIFO="/tmp/laser_cmd"
SDP="/tmp/laser_guidance.sdp"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
STORE="$SCRIPT_DIR/.config-path"
CONFIG="${1:-}"
[ -z "$CONFIG" ] && CONFIG="$(cat "$STORE" 2>/dev/null || echo "$REPO_ROOT/config/default.yaml")"

# Extract RTP port from config
RTP_PORT=$(python3 -c "
import yaml
with open('$CONFIG') as f:
    cfg = yaml.safe_load(f)
print(cfg.get('streaming', {}).get('port', 5004))
")
RTP_HOST=$(python3 -c "
import yaml
with open('$CONFIG') as f:
    cfg = yaml.safe_load(f)
print(cfg.get('streaming', {}).get('host', '127.0.0.1'))
")

cleanup() { kill %1 2>/dev/null; rm -f "$TMP_CONFIG" "$SDP"; }
trap cleanup EXIT

if [ -p "$FIFO" ] && timeout 1 bash -c "echo 'stream on' > '$FIFO'" 2>/dev/null; then
    cat > "$SDP" << SDPEOF
v=0
o=- 0 0 IN IP4 $RTP_HOST
s=No Name
c=IN IP4 $RTP_HOST
t=0 0
m=video $RTP_PORT RTP/AVP 96
a=rtpmap:96 H264/90000
a=fmtp:96 packetization-mode=1
SDPEOF
    ffplay -hide_banner -loglevel warning -nostats -protocol_whitelist file,rtp,udp -fflags nobuffer -flags low_delay "$SDP"
    exit 0
fi

rm -f "$SDP"
# Kill any stale daemon from previous runs
pkill -f "example_v4l2_preview" 2>/dev/null || true
sleep 0.3
TMP_CONFIG="$(mktemp /tmp/laser_guidance_stream_XXXX.yaml)"
python3 -c "
import yaml, sys
with open('$CONFIG') as f:
    cfg = yaml.safe_load(f)
cfg.setdefault('streaming', {})['enabled'] = True
cfg.setdefault('debug', {})['show_window'] = False
yaml.dump(cfg, sys.stdout, default_flow_style=False, allow_unicode=True)
" > "$TMP_CONFIG"

cat > "$SDP" << SDPEOF
v=0
o=- 0 0 IN IP4 $RTP_HOST
s=No Name
c=IN IP4 $RTP_HOST
t=0 0
m=video $RTP_PORT RTP/AVP 96
a=rtpmap:96 H264/90000
a=fmtp:96 packetization-mode=1
SDPEOF

cd "$REPO_ROOT"
./build/example_v4l2_preview "$TMP_CONFIG" &>/dev/null &
ffplay -hide_banner -loglevel warning -nostats -protocol_whitelist file,rtp,udp -fflags nobuffer -flags low_delay "$SDP"
