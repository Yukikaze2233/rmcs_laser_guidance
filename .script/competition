#!/usr/bin/env bash
set -euo pipefail
FIFO="/tmp/laser_cmd"
SDP="/tmp/laser_guidance.sdp"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
STORE="$SCRIPT_DIR/.config-path"
CONFIG="${1:-}"
[ -z "$CONFIG" ] && CONFIG="$(cat "$STORE" 2>/dev/null || echo "$REPO_ROOT/config/direct_voltage_run.yaml")"

cleanup() { kill %1 2>/dev/null || true; rm -f "$TMP_CONFIG" "$SDP"; }
trap cleanup EXIT

TMP_CONFIG=""

eval "$(python3 -c "
import yaml
with open('$CONFIG') as f:
    cfg = yaml.safe_load(f)
host = cfg.get('streaming', {}).get('host', '127.0.0.1')
port = cfg.get('streaming', {}).get('port', 5004)
enabled = cfg.get('streaming', {}).get('enabled', False)
print(f'RTP_HOST={host}')
print(f'RTP_PORT={port}')
print(f'STREAMING_ENABLED={enabled}')
")"

launch_ffplay() {
    cat > "$SDP" << SDPEOF
v=0
o=- 0 0 IN IP4 $RTP_HOST
s=No Name
c=IN IP4 $RTP_HOST
t=0 0
m=video $RTP_PORT RTP/AVP 96
a=rtpmap:96 H264/90000
a=fmtp:96 packetization-mode=1
SDPEOF
    ffplay -hide_banner -loglevel warning -nostats -protocol_whitelist file,rtp,udp -fflags nobuffer -flags low_delay -probesize 32 -analyzeduration 0 -sync ext "$SDP"
}

# Daemon already running — just show viewer
if [ -p "$FIFO" ] && timeout 1 bash -c "echo 'stream on' > '$FIFO'" 2>/dev/null; then
    echo "competition daemon already running"
    if [ "$STREAMING_ENABLED" = "True" ]; then
        launch_ffplay
    else
        echo "streaming disabled in config; FIFO: echo '<cmd>' > $FIFO"
        echo "  stream on/off | record on/off | enemy red/blue/auto | backend tensorrt/onnx | quit"
        while true; do sleep 1; done
    fi
    exit 0
fi

# Cold start
pkill -9 -f "tool_competition" 2>/dev/null || true
pkill -9 -f "tool_preview" 2>/dev/null || true
TMP_CONFIG="$(mktemp /tmp/laser_guidance_competition_XXXX.yaml)"

python3 -c "
import yaml
with open('$CONFIG') as f:
    cfg = yaml.safe_load(f)
cfg.setdefault('debug', {})['show_window'] = False
with open('$TMP_CONFIG', 'w') as f:
    yaml.dump(cfg, f, default_flow_style=False, allow_unicode=True)
"

cd "$REPO_ROOT"
rm -f "$SDP"
echo "=== 比赛模式 (守护进程) ==="
echo "配置: $CONFIG"
echo "日志: /tmp/laser_competition.log"
./build/tool_competition "$TMP_CONFIG" >/dev/null 2>/tmp/laser_competition.log &
echo "PID: $!"
echo ""
echo "FIFO 控制命令:"
echo "  stream on/off           推流开关"
echo "  record on/off           录制开关"
echo "  enemy red/blue/auto     敌方颜色"
echo "  backend tensorrt/onnx   推理后端"
echo "  quit                    退出"

if [ "$STREAMING_ENABLED" = "True" ]; then
    for i in $(seq 1 50); do
        [ -s "$SDP" ] && break
        sleep 0.05
    done
    launch_ffplay
else
    wait
fi
